<Module
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../FrankConfig.xsd"
>
    <Adapter name="readKanaalAdapter">
        <Receiver name="readKanaalReceiver">
            <ApiListener
                    name="readKanaalListener"
                    uriPattern="/kanaal/{uuid}"
                    method="GET"
                    headerParams="Authorization"
                    allowAllParams="false"
                    produces="JSON"/>
        </Receiver>
        <Pipeline>
            <Exits>
                <Exit name="OK" state="SUCCESS" code="200"/>
                <Exit name="Unauthorized" state="ERROR" code="401"/>
                <Exit name="Forbidden" state="ERROR" code="403"/>
                <Exit name="NotFound" state="ERROR" code="404"/>
                <Exit name="NotAcceptable" state="ERROR" code="406"/>
                <Exit name="Conflict" state="ERROR" code="409"/>
                <Exit name="Gone" state="ERROR" code="410"/>
                <Exit name="PreconditionFailed" state="ERROR" code="412"/>
                <Exit name="UnsupportedMediaType" state="ERROR" code="415"/>
                <Exit name="TooManyRequests" state="ERROR" code="429"/>
                <Exit name="InternalServerError" state="ERROR" code="500"/>
            </Exits>

            <SenderPipe name="checkAuth">
                <FrankSender target="Auth/authCheck"/>
                <Param name="authorization"
                       sessionKey="headers"
                       xpathExpression="headers/header[@name='Authorization']"/>
                <Param name="requiredScopes" value='["notificaties.publiceren", "notifcaties.consumeren"]'/>
            </SenderPipe>

            <SwitchPipe name="authResult">
                <Forward name="200" path="readKanaalSender"/>
                <Forward name="401" path="unauthorizedError"/>
                <Forward name="403" path="forbiddenError"/>
            </SwitchPipe>

            <SenderPipe name="unauthorizedError">
                <FrankSender target="Errors/errorResponse"/>
                <Param name="status" value="401"/>
                <Param name="code" value="authentication_failed"/>
                <Param name="title" value="Authentication credentials were not provided."/>
                <Param name="detail" value="Authentication credentials were not provided."/>
                <Param name="instance" value="kanaal"/>
                <Forward name="success" path="Unauthorized"/>
            </SenderPipe>

            <SenderPipe name="forbiddenError">
                <FrankSender target="Errors/errorResponse"/>
                <Param name="status" value="403"/>
                <Param name="code" value="permission_denied"/>
                <Param name="title" value="You do not have permission to perform this action."/>
                <Param name="detail" value="You do not have permission to perform this action."/>
                <Param name="instance" value="kanaal"/>
                <Forward name="success" path="Forbidden"/>
            </SenderPipe>

            <SenderPipe name="readKanaalSender">
                <FixedQuerySender
                        name="readKanaalQuerySender"
                        queryType="SELECT"
                        query="SELECT uuid, naam, documentatie_link, filters FROM kanaal WHERE uuid = ?"
                        outputFormat="JSON"
                        datasourceName="jdbc/notificatiecomponent"/>
                <Param name="uuid" sessionKey="uuid"/>
            </SenderPipe>

            <IfPipe name="kanaalExistsCheck"
                    expressionValue="0"
                    jsonPathExpression="$.rowset.length()">
                <Forward name="then" path="notFoundError"/>
                <Forward name="else" path="readKanaalMap"/>
            </IfPipe>

            <SenderPipe name="notFoundError">
                <FrankSender target="Errors/errorResponse"/>
                <Param name="status" value="404"/>
                <Param name="code" value="not_found"/>
                <Param name="title" value="Not found."/>
                <Param name="detail" sessionKey="uuid" pattern="No kanaal with uuid {uuid} found."/>
                <Param name="instance" sessionKey="uuid" pattern="/api/v1/kanaal/{uuid}"/>
                <Forward name="success" path="NotFound"/>
            </SenderPipe>

            <DataSonnetPipe
                    name="readKanaalMap"
                    styleSheetName="ds/kanaal-read.ds">
                <Forward name="success" path="OK"/>
            </DataSonnetPipe>
        </Pipeline>
    </Adapter>
</Module>