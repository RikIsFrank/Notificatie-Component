<Module
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../FrankConfig.xsd">

    <Adapter name="authCheck">

        <Receiver name="authCheckReceiver">
            <FrankListener/>
        </Receiver>

        <Pipeline>

            <Exits>
                <Exit name="success" state="SUCCESS" code="200"/>
                <Exit name="unauthorized" state="ERROR" code="401"/>
                <Exit name="forbidden" state="ERROR" code="403"/>
            </Exits>

            <SenderPipe name="decodeAndValidateJwt">
                <JavascriptSender jsFileName="AuthCheck.js" jsFunctionName="decodeAndValidate"/>
                <Param name="jwt" sessionKey="authorization"/>
            </SenderPipe>

            <PutInSessionPipe name="storeDecodeResult" sessionKey="decodeResult"/>

            <IfPipe name="checkDecodeStatus"
                    expressionValue="200"
                    jsonPathExpression="$.status">
                <Forward name="then" path="extractClientId"/>
                <Forward name="else" path="unauthorized"/>
            </IfPipe>

            <EchoPipe name="extractClientId" getInputFromSessionKey="decodeResult"/>

            <JsonPathPipe name="parseClientId" jsonPathExpression="$.clientId">
                <Forward name="success" path="storeClientId"/>
                <Forward name="exception" path="unauthorized"/>
            </JsonPathPipe>

            <PutInSessionPipe name="storeClientId" sessionKey="clientId"/>

            <SenderPipe name="lookupSecret">
                <FixedQuerySender
                        name="lookupSecretQuery"
                        queryType="SELECT"
                        query="SELECT secret FROM jwt_secret WHERE client_id = ?"
                        datasourceName="jdbc/notificatiecomponent"
                        outputFormat="JSON">
                    <Param name="1" sessionKey="clientId"/>
                </FixedQuerySender>
                <Forward name="success" path="checkSecretFound"/>
                <Forward name="failure" path="unauthorized"/>
            </SenderPipe>

            <IfPipe name="checkSecretFound"
                    expressionValue="0"
                    jsonPathExpression="$.rowset.length()">
                <Forward name="then"  path="unauthorized"/>
                <Forward name="else" path="storeSecret"/>
            </IfPipe>

            <PutInSessionPipe name="storeSecret" sessionKey="jwtSecret"/>

            <SenderPipe name="verifyHmac">
                <JavascriptSender jsFileName="AuthCheck.js" jsFunctionName="verifyHmac"/>
                <Param name="jwt" sessionKey="authorization"/>
                <Param name="secretJson" sessionKey="jwtSecret"/>
            </SenderPipe>

            <SwitchPipe name="hmacResult">
                <Forward name="200" path="generateJwt"/>
                <Forward name="401" path="unauthorized"/>
            </SwitchPipe>

            <!-- query AC -->
            <JwtPipe name="generateJwt"
                     storeResultInSessionKey="myToken"
                     sharedSecret="${nc.zgw.autorisaties-api.jwt-secret}">
                <Param name="sharedSecret" pattern="{password}" authAlias="${nc.zgw.autorisaties-api.auth-alias}" hidden="true"/>
                <Param name="iss" pattern="{username}" authAlias="${nc.zgw.autorisaties-api.auth-alias}" hidden="true"/>
                <Param name="client_id" pattern="{username}" authAlias="${nc.zgw.autorisaties-api.auth-alias}" hidden="true"/>
                <Param name="user_id" pattern="{username}" authAlias="${nc.zgw.autorisaties-api.auth-alias}" hidden="true"/>
                <Param name="user_representation" pattern="{username}" authAlias="${nc.zgw.autorisaties-api.auth-alias}" hidden="true"/>
            </JwtPipe>

            <SenderPipe name="queryAuthorizationComponent">
                <HttpSender name="authComponentQuerySender"
                            methodType="GET"
                            contentType="application/json"
                            headersParams="Authorization,Accept-Crs,Content-Crs,Accept"
                            url="${nc.zgw.autorisaties-api.root-url}/applicaties/consumer">
                    <Param name="Authorization" pattern="Bearer {myToken}">
                        <Param name="myToken" sessionKey="myToken"/>
                    </Param>
                    <Param name="Accept-Crs" value="EPSG:4326" />
                    <Param name="Content-Crs" value="EPSG:4326" />
                    <Param name="Accept" value="application/json" />
                    <Param name="clientId" sessionKey="clientId"/>
                </HttpSender>
            </SenderPipe>

            <PutInSessionPipe name="storeAcResponse" sessionKey="acResponse"/>

            <IfPipe name="checkHeeftAlleAutorisaties"
                    expressionValue="true"
                    jsonPathExpression="$.heeftAlleAutorisaties">
                <Forward name="then" path="clearResponse"/>
                <Forward name="else" path="checkScopeResult"/>
            </IfPipe>

            <SenderPipe name="checkScopeResult">
                <JavascriptSender jsFileName="AuthCheck.js" jsFunctionName="checkScopes"/>
                <Param name="acResponseJson" sessionKey="acResponse"/>
                <Param name="requiredScopesJson" sessionKey="requiredScopes"/>
            </SenderPipe>

            <SwitchPipe name="scopeResult">
                <Forward name="200" path="clearResponse"/>
                <Forward name="401" path="failClearResponse"/>
            </SwitchPipe>

            <!-- Need a better / cleaner solution for this -->
            <EchoPipe name="clearResponse" getInputFromFixedValue="200">
                <Forward name="success" path="success"/>
            </EchoPipe>

            <EchoPipe name="failClearResponse" getInputFromFixedValue="401">
                <Forward name="success" path="unauthorized"/>
            </EchoPipe>

        </Pipeline>
    </Adapter>

</Module>