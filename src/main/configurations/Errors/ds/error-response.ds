local statusStr = payload.status;
local statusInt = std.parseInt(statusStr);
local invParams = payload.invalidParams;

local typeUrls = {
    "400": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/400 400 Bad Request",
    "401": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/401 401 Unauthorized",
    "403": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/403 403 Forbidden",
    "404": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/404 404 Not Found",
    "406": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/406 406 Not Acceptable",
    "409": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/409 409 Conflict",
    "410": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/410 410 Gone",
    "412": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/412 412 Precondition Failed",
    "415": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/415 415 Unsupported Media Type",
    "429": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/429 429 Too Many Requests",
    "500": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Status/500 500 Internal Server Error",
};

{
    type: typeUrls[statusStr],
    code: payload.code,
    title: payload.title,
    status: statusInt,
    detail: payload.detail,
    instance: payload.instance,
    [if std.length(invParams) > 0 then "invalidParams"]: {
        name: "Bad Request - Invalid Parameters",
        code: "400",
        reason: invParams,
    },
}
