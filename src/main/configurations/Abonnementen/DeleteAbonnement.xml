<Module
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../FrankConfig.xsd"
>
    <Adapter name="deleteAbonnementAdapter">
        <Receiver name="deleteAbonnementReceiver">
            <ApiListener
                    name="deleteAbonnementListener"
                    uriPattern="/abonnement/{uuid}"
                    method="DELETE"
                    headerParams="Authorization"
                    allowAllParams="false"
                    produces="JSON"/>
        </Receiver>
        <Pipeline>
            <Exits>
                <Exit name="NoContent" state="SUCCESS" code="204"/>
                <Exit name="BadRequest" state="ERROR" code="400"/>
                <Exit name="Unauthorized" state="ERROR" code="401"/>
                <Exit name="Forbidden" state="ERROR" code="403"/>
                <Exit name="NotFound" state="ERROR" code="404"/>
                <Exit name="NotAcceptable" state="ERROR" code="406"/>
                <Exit name="Conflict" state="ERROR" code="409"/>
                <Exit name="Gone" state="ERROR" code="410"/>
                <Exit name="PreconditionFailed" state="ERROR" code="412"/>
                <Exit name="UnsupportedMediaType" state="ERROR" code="415"/>
                <Exit name="TooManyRequests" state="ERROR" code="429"/>
                <Exit name="InternalServerError" state="ERROR" code="500"/>
            </Exits>

            <PutInSessionPipe name="setInstance" value="abonnement" sessionKey="responseInstance">
                <Forward name="success" path="checkAuth"/>
            </PutInSessionPipe>

            <SenderPipe name="checkAuth">
                <FrankSender target="Auth/authCheck"/>
                <Param name="authorization"
                       sessionKey="headers"
                       xpathExpression="headers/header[@name='Authorization']"/>
                <Param name="requiredScopes" value='["notifcaties.consumeren"]'/>
            </SenderPipe>

            <SwitchPipe name="authResult">
                <Forward name="200" path="checkAbonnementExists"/>
                <Forward name="401" path="unauthorizedError"/>
                <Forward name="403" path="forbiddenError"/>
            </SwitchPipe>

            <Include ref="CommonResponses.xml"/>

            <!-- Check if the abonnement exists before attempting deletion -->
            <SenderPipe name="checkAbonnementExists">
                <FixedQuerySender
                        queryType="SELECT"
                        query="SELECT COUNT(*) AS count FROM abonnement WHERE uuid = ?"
                        outputFormat="JSON"
                        datasourceName="jdbc/notificatiecomponent"/>
                <Param name="uuid" sessionKey="uuid"/>
            </SenderPipe>

            <IfPipe name="abonnementExistsCheck"
                    expressionValue="0"
                    jsonPathExpression="$.rowset[0].COUNT">
                <Forward name="then" path="notFoundError"/>
                <Forward name="else" path="deleteAbonnementSender"/>
            </IfPipe>

            <!--
                Delete the abonnement. The FK constraints on filter_group and filter
                both have deleteCascade="true", so all related rows are removed automatically.
            -->
            <SenderPipe name="deleteAbonnementSender">
                <FixedQuerySender
                        query="DELETE FROM abonnement WHERE uuid = ?"
                        queryType="OTHER"
                        datasourceName="jdbc/notificatiecomponent"/>
                <Param name="uuid" sessionKey="uuid"/>
            </SenderPipe>

            <!-- Need a better / cleaner solution for this -->
            <EchoPipe name="clearResponse" getInputFromFixedValue="204">
                <Forward name="success" path="NoContent"/>
            </EchoPipe>
        </Pipeline>
    </Adapter>
</Module>