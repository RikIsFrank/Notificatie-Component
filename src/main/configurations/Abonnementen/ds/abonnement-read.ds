local rows = payload.rowset;
local base = 'http://localhost/api/v1/abonnement/';

// Group rows by abonnement uuid
local abonnementUuids = std.uniq(std.map(function(r) r.UUID, rows));

std.map(function(uuid)
local abonnementRows = std.filter(function(r) r.UUID == uuid, rows);
local firstRow = abonnementRows[0];

// Group rows by filter_group_id to build kanalen
local fgIds = std.uniq(std.map(function(r) r.ID, abonnementRows));

local kanalen = std.map(function(fgId)
local fgRows = std.filter(function(r) r.ID == fgId, abonnementRows);
local firstFgRow = fgRows[0];

// Build filters object from key/value rows, skip rows with null key (abonnement with no filters)
local filterRows = std.filter(function(r) r.FILTER_KEY != null, fgRows);
local filters = std.foldl(
function(acc, r) acc {[r.FILTER_KEY]: r.FILTER_VALUE},
filterRows,
{}
);

{
  filters: filters,
  naam: firstFgRow.NAAM,
}, fgIds);

{
  url: base + uuid,
  auth: firstRow.AUTH,
  callbackUrl: firstRow.CALLBACK_URL,
  kanalen: kanalen,
}, abonnementUuids
)
[0]
