<Module
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../FrankConfig.xsd"
    >
    <Adapter name="AbonneeAdapter">
        <Receiver name="ApiReceiver">
            <ApiListener
                    name="AbonneeListener"
                    uriPattern="/api/abonnement"
                    method="POST"/>
        </Receiver>

        <Pipeline>

            <Exits>
                <Exit name="success" state="SUCCESS"/>
                <Exit name="failure" state="ERROR"/>
            </Exits>

            <JsonValidatorPipe
                    name="AbonneeValidator"
                    schema="abonnee-schema.json">
                <Forward name="success" path="AbonneeSender" />
                <Forward name="failure" path="failure" />
            </JsonValidatorPipe>

            <SenderPipe name="AbonneeSender">
                <FixedQuerySender
                        datasourceName="jdbc/notificatiecomponent"
                        query="INSERT INTO abonnement (...) VALUES (...)">

                </FixedQuerySender>
                <Forward name="success" path="success" />
            </SenderPipe>

        </Pipeline>
    </Adapter>
</Module>