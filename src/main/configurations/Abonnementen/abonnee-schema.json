{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/open-notificatie-abonnement.json",
  "title": "Open Notificatie Abonnement",
  "type": "object",
  "additionalProperties": false,
  "required": ["callbackUrl", "auth", "kanalen"],
  "properties": {
    "callbackUrl": {
      "type": "string",
      "format": "uri",
      "description": "De URL waar notificaties naartoe worden gestuurd (HTTPS verplicht in productie)."
    },
    "auth": {
      "type": "string",
      "description": "Authenticatie token dat wordt meegestuurd in de notificatie (Authorization header)."
    },
    "kanalen": {
      "type": "array",
      "minItems": 1,
      "description": "Lijst van kanalen waarop geabonneerd wordt.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["naam"],
        "properties": {
          "naam": {
            "type": "string",
            "minLength": 1,
            "description": "Naam van het kanaal (bijv. 'zaken', 'besluiten', 'documenten')."
          },
          "filters": {
            "type": "object",
            "description": "Optionele filters om notificaties te beperken.",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
