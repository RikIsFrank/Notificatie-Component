<Module
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../FrankConfig.xsd"
>
    <Adapter name="createNotificatieAdapter">
        <Receiver name="createNotificatieReceiver">
            <ApiListener
                    name="createNotificatieListener"
                    uriPattern="/notificatie"
                    method="POST"
                    headerParams="Authorization"
                    allowAllParams="false"
                    consumes="JSON"
                    produces="JSON"/>
        </Receiver>
        <Pipeline>
            <JsonInputValidator name="validateCreateNotificatieInput"
                                schema="json/create-notificatie-schema.json">
                <Forward name="success" path="setInstance"/>
                <Forward name="failure" path="buildValidationInvalidParams"/>
            </JsonInputValidator>

            <Exits>
                <Exit name="OK" state="SUCCESS" code="201"/>
                <Exit name="BadRequest" state="ERROR" code="400"/>
                <Exit name="Unauthorized" state="ERROR" code="401"/>
                <Exit name="Forbidden" state="ERROR" code="403"/>
                <Exit name="NotFound" state="ERROR" code="404"/>
                <Exit name="NotAcceptable" state="ERROR" code="406"/>
                <Exit name="Conflict" state="ERROR" code="409"/>
                <Exit name="Gone" state="ERROR" code="410"/>
                <Exit name="PreconditionFailed" state="ERROR" code="412"/>
                <Exit name="UnsupportedMediaType" state="ERROR" code="415"/>
                <Exit name="TooManyRequests" state="ERROR" code="429"/>
                <Exit name="InternalServerError" state="ERROR" code="500"/>
            </Exits>

            <PutInSessionPipe name="setInstance" value="notificatie" sessionKey="responseInstance">
                <Forward name="success" path="checkAuth"/>
            </PutInSessionPipe>

            <SenderPipe name="checkAuth">
                <FrankSender target="Auth/authCheck"/>
                <Param name="authorization"
                       sessionKey="headers"
                       xpathExpression="headers/header[@name='Authorization']"/>
                <Param name="requiredScopes" value='["notificaties.publiceren"]'/>
            </SenderPipe>

            <SwitchPipe name="authResult">
                <Forward name="200" path="notificatieJsonConverter"/>
                <Forward name="401" path="unauthorizedError"/>
                <Forward name="403" path="forbiddenError"/>
            </SwitchPipe>

            <Include ref="CommonResponses.xml"/>

            <ReplacerPipe name="buildValidationInvalidParams"
                          getInputFromSessionKey="failureReason"
                          getInputFromFixedValue='"?{validationException}"'>
                <Param name="validationException" sessionKey="failureReason"/>
                <Forward name="success" path="storeInvalidParams"/>
            </ReplacerPipe>

            <PutInSessionPipe name="storeInvalidParams" sessionKey="invalidParams">
                <Forward name="success" path="badRequestError"/>
            </PutInSessionPipe>

            <JsonPipe name="notificatieJsonConverter"
                      getInputFromSessionKey="originalMessage"
                      storeResultInSessionKey="originalMessageXml">
                <Forward name="success" path="checkKanalenNamesExists"/>
            </JsonPipe>

            <!-- check if kanalen exists (foreach) -->
            <ForEachChildElementPipe name="checkKanalenNamesExists" targetElement="naam">
                <FixedQuerySender query="SELECT COUNT(*) AS count FROM kanaal WHERE naam = ?"
                                  queryType="SELECT"
                                  datasourceName="jdbc/notificatiecomponent"
                                  outputFormat="XML"/>
                <Param name="naam" xpathExpression="naam"/>
            </ForEachChildElementPipe>

            <!-- check if value is 0 somewhere (kanaal doesnt exist) -->
            <SwitchPipe name="checkKanalenNamesExistsCheck"
                        xpathExpression="//row/COUNT=0">

                <Forward name="false" path="checkOtherExists"/>
                <Forward name="true" path="badRequestError"/>
                <!-- forward this to another pipe to extract wanted values and store those in invalidParams -->
            </SwitchPipe>
            
            <!-- check if other things exists (foreach) -->
            <EchoPipe name="checkOtherExists" getInputFromFixedValue="TODO: check other values like notificatieType, bron, etc."/>

        </Pipeline>
    </Adapter>
</Module>
