<Module
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="../FrankConfig.xsd"
>
    <Adapter name="createNotificatieAdapter">
        <Receiver name="createNotificatieReceiver">
            <ApiListener
                    name="createNotificatieListener"
                    uriPattern="notificaties"
                    method="POST"
                    headerParams="Authorization"
                    allowAllParams="false"
                    consumes="JSON"
                    produces="JSON"/>
        </Receiver>
        <Pipeline>
            <JsonInputValidator name="validateCreateNotificatieInput"
                                schema="json/create-notificatie-schema.json">
                <Forward name="success" path="setInstance"/>
                <Forward name="failure" path="buildValidationInvalidParams"/>
            </JsonInputValidator>

            <Exits>
                <Exit name="OK" state="SUCCESS" code="201"/>
                <Exit name="BadRequest" state="ERROR" code="400"/>
                <Exit name="Unauthorized" state="ERROR" code="401"/>
                <Exit name="Forbidden" state="ERROR" code="403"/>
                <Exit name="NotFound" state="ERROR" code="404"/>
                <Exit name="NotAcceptable" state="ERROR" code="406"/>
                <Exit name="Conflict" state="ERROR" code="409"/>
                <Exit name="Gone" state="ERROR" code="410"/>
                <Exit name="PreconditionFailed" state="ERROR" code="412"/>
                <Exit name="UnsupportedMediaType" state="ERROR" code="415"/>
                <Exit name="TooManyRequests" state="ERROR" code="429"/>
                <Exit name="InternalServerError" state="ERROR" code="500"/>
            </Exits>

            <PutInSessionPipe name="setInstance" value="notificatie" sessionKey="responseInstance">
                <Forward name="success" path="checkAuth"/>
            </PutInSessionPipe>

            <SenderPipe name="checkAuth">
                <FrankSender target="Auth/authCheck"/>
                <Param name="authorization"
                       sessionKey="headers"
                       xpathExpression="headers/header[@name='Authorization']"/>
                <Param name="requiredScopes" value='["notificaties.publiceren"]'/>
            </SenderPipe>

            <SwitchPipe name="authResult">
                <Forward name="200" path="notificatieJsonConverter"/>
                <Forward name="401" path="unauthorizedError"/>
                <Forward name="403" path="forbiddenError"/>
            </SwitchPipe>

            <Include ref="CommonResponses.xml"/>

            <ReplacerPipe name="buildValidationInvalidParams"
                          getInputFromSessionKey="failureReason"
                          getInputFromFixedValue='"?{validationException}"'>
                <Param name="validationException" sessionKey="failureReason"/>
                <Forward name="success" path="storeInvalidParams"/>
            </ReplacerPipe>

            <PutInSessionPipe name="storeInvalidParams" sessionKey="invalidParams">
                <Forward name="success" path="badRequestError"/>
            </PutInSessionPipe>

            <JsonPipe name="notificatieJsonConverter"
                      getInputFromSessionKey="originalMessage"
                      storeResultInSessionKey="originalMessageXml">
                <Forward name="success" path="checkKanaalNameExists"/>
            </JsonPipe>

            <SenderPipe name="checkKanaalNameExists">
                <FixedQuerySender query="SELECT id FROM kanaal WHERE naam = ?"
                                  queryType="SELECT"
                                  datasourceName="jdbc/notificatiecomponent"
                                  outputFormat="XML"/>
                <Param name="naam" xpathExpression="//kanaal"/>
            </SenderPipe>

            <!-- check if 1 id is returned -->
            <SwitchPipe name="checkKanaalNameExistsCheck"
                        xpathExpression="count(//row/ID)=1">
                <Forward name="true" path="storeKanaalId"/>
                <Forward name="false" path="badRequestError"/>
                <!-- forward this to another pipe to extract wanted values and store those in invalidParams -->
            </SwitchPipe>

            <PutInSessionPipe name="storeKanaalId">
                <Param name="kanaalId" xpathExpression="//row/ID"/>
                <Forward name="success" path="createNotificatie"/>
            </PutInSessionPipe>

            <!-- ToDo kijk als extra checks nodig zijn (hoofdObject, resource, resourceUrl) -->

            <SenderPipe name="createNotificatie">
                <FixedQuerySender query="INSERT INTO notificatie (kanaal_id, forwarded_msg) VALUES (?, ?)"
                                  queryType="OTHER"
                                  datasourceName="jdbc/notificatiecomponent"/>
                <Param name="kanaal_id" sessionKey="kanaalId"/>
                <Param name="forwarded_msg" sessionKey="originalMessage"/>
            </SenderPipe>

            <!-- get the autogenerated id -->
            <SenderPipe name="getNotificatieId">
                <FixedQuerySender query="SELECT id FROM notificatie WHERE kanaal_id = ? AND forwarded_msg = ?
                ORDER BY id DESC LIMIT 1"
                                  queryType="SELECT"
                                  datasourceName="jdbc/notificatiecomponent"
                                  outputFormat="XML"/>
                <Param name="kanaal_id" sessionKey="kanaalId"/>
                <Param name="forwarded_msg" sessionKey="originalMessage"/>
            </SenderPipe>

            <PutInSessionPipe name="storeNotificatieId">
                <Param name="notificatieId" xpathExpression="//row/ID"/>
            </PutInSessionPipe>

            <PutInSessionPipe name="storeNotificatieJson"
                              getInputFromSessionKey="originalMessage"
                              sessionKey="notificatieJson"/>

            <SenderPipe name="getWebhookUrls">
                <FixedQuerySender query="SELECT
                                            abonnement.id,
                                            abonnement.uuid,
                                            abonnement.callback_url,
                                            abonnement.auth
                                        FROM abonnement
                                        LEFT JOIN filter_group as fg
                                        on fg.abonnement_id = abonnement.id
                                        WHERE fg.kanaal_id = ?"
                                  queryType="SELECT"
                                  datasourceName="jdbc/notificatiecomponent"
                                  outputFormat="XML"/>
                <Param name="kanaal_id" sessionKey="kanaalId"/>
            </SenderPipe>

            <ForEachChildElementPipe name="sendToWebhooks" targetElement="row">
                <MessageStoreSender
                        slotId="webhook-notificaties"
                        onlyStoreWhenMessageIdUnique="false"
                        sessionKeys="notificatieId,notificatieJson"/>
            </ForEachChildElementPipe>

            <EchoPipe name="setResponse" getInputFromSessionKey="originalMessage"/>
        </Pipeline>
    </Adapter>



    <Adapter name="notifyAbonnementAndSaveResponseAdapter">
        <Receiver name="notifyAbonnementAndSaveResponseReceiver">
            <MessageStoreListener
                    name="sendWebhookNotificatieListener"
                    slotId="webhook-notificaties"
                    sessionKeys="notificatieId,notificatieJson"/>
        </Receiver>
        <Pipeline>
            <Exits>
                <Exit name="success" state="SUCCESS"/>
            </Exits>

            <PutInSessionPipe name="storeAbonnementRow" sessionKey="abonnementRow"/>

            <SenderPipe name="sendToWebhook" getInputFromSessionKey="notificatieJson">
                <HttpSender
                        name="webhookHttpSender"
                        methodType="POST"
                        headersParams="Authorization,content-type"
                        resultStatusCodeSessionKey="responseCode"/>
                <Param name="url" sessionKey="abonnementRow" xpathExpression="//CALLBACK_URL"/>
                <Param name="Authorization" sessionKey="abonnementRow" xpathExpression="//AUTH"/>
                <Param name="content-type" value="application/json"/>
            </SenderPipe>

            <!-- Fail loudly on non-2xx so the message lands in the error store and can be resent from Frank!Console. -->
            <SwitchPipe name="checkWebhookResponse" getInputFromSessionKey="responseCode">
                <Forward name="200" path="storeWebhookResponse"/>
                <Forward name="201" path="storeWebhookResponse"/>
                <Forward name="202" path="storeWebhookResponse"/>
                <Forward name="203" path="storeWebhookResponse"/>
                <Forward name="204" path="storeWebhookResponse"/>
                <Forward name="205" path="storeWebhookResponse"/>
                <Forward name="206" path="storeWebhookResponse"/>
                <Forward name="207" path="storeWebhookResponse"/>
                <Forward name="208" path="storeWebhookResponse"/>
                <Forward name="226" path="storeWebhookResponse"/>
            </SwitchPipe>

            <SenderPipe name="storeWebhookResponse">
                <FixedQuerySender
                        query="INSERT INTO notificatie_response (notificatie_id, abonnement_id, response_status) VALUES (?, ?, ?)"
                        queryType="OTHER"
                        datasourceName="jdbc/notificatiecomponent"/>
                <Param name="notificatie_id" sessionKey="notificatieId"/>
                <Param name="abonnement_id" sessionKey="abonnementRow" xpathExpression="//ID"/>
                <Param name="response_status" sessionKey="responseCode"/>
            </SenderPipe>
        </Pipeline>
    </Adapter>

</Module>
